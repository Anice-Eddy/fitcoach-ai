# ============================================================
# FITCOACH AI - Environment variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any real secret to Git.
# ============================================================

# ------------------------------------------------------------
# DATABASE - Neon PostgreSQL
# https://neon.tech -> create a project -> copy the URL
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host/BodyOps?sslmode=require"

# ------------------------------------------------------------
# SESSION - NextAuth remains the internal session layer.
# AUTH_SECRET: generate with `openssl rand -base64 32`.
# AUTH_URL: http://localhost:3000 in development, Vercel URL in production.
# ------------------------------------------------------------
AUTH_SECRET="REPLACE_WITH_32_CHARACTER_SECRET"
AUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# STRIPE
# https://dashboard.stripe.com -> Developers -> API Keys
# STRIPE_WEBHOOK_SECRET : stripe listen --forward-to localhost:3000/api/stripe/webhook
# ------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe product/price IDs, created from the Stripe dashboard.
STRIPE_PRO_MONTHLY_ID="price_..."
STRIPE_PRO_YEARLY_ID="price_..."
STRIPE_ELITE_MONTHLY_ID="price_..."
STRIPE_ELITE_YEARLY_ID="price_..."
STRIPE_BUSINESS_ID="price_..."

# ------------------------------------------------------------
# FITNESS INTEGRATIONS - optional for the MVP.
# Keep empty until each provider is enabled.
# ------------------------------------------------------------

# Strava — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""

# Fitbit — https://dev.fitbit.com/apps
FITBIT_CLIENT_ID=""
FITBIT_CLIENT_SECRET=""

# Garmin — https://developer.garmin.com
GARMIN_CLIENT_ID=""
GARMIN_CLIENT_SECRET=""

# ------------------------------------------------------------
# AFFILIATE
# Amazon Associates : https://affiliate-program.amazon.com
# ------------------------------------------------------------
AMAZON_AFFILIATE_TAG=""

# ------------------------------------------------------------
# APP
# NEXT_PUBLIC_* is exposed to the browser. Never put secrets here.
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ------------------------------------------------------------
# AUTH - Firebase is the default user-facing identity provider.
# nextauth = legacy login only
# firebase = Firebase login/register + internal session for existing routes
# hybrid   = rollback/migration mode with both systems available
# ------------------------------------------------------------
AUTH_PROVIDER="firebase"
NEXT_PUBLIC_AUTH_PROVIDER="firebase"

# ------------------------------------------------------------
# FIREBASE AUTH - Client SDK
# Firebase Console -> Project settings -> General -> Web app config.
# NEXT_PUBLIC_* is visible in the browser; these values are not Admin secrets.
# ------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# ------------------------------------------------------------
# FIREBASE AUTH - Admin SDK
# Firebase Console -> Project settings -> Service accounts.
# Recommended option: paste the full JSON into FIREBASE_SERVICE_ACCOUNT_JSON.
# Locally, keep private_key newlines escaped as \n.
# ------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Alternative option if you do not want to use the full JSON.
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""

# Legacy-compatible variables kept during the migration.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ------------------------------------------------------------
# AI - Providers
# GROQ_MODEL can be changed without code edits if Groq deprecates a model.
# ------------------------------------------------------------
GROQ_API_KEY=""
GROQ_MODEL="openai/gpt-oss-120b"
GEMINI_API_KEY=""

# ------------------------------------------------------------
# FACEBOOK LOGIN - used by Firebase Auth as provider configuration.
# Facebook Developer Console -> App settings.
# NEXT_PUBLIC_FACEBOOK_APP_ID is public; FACEBOOK_APP_SECRET stays server-side.
# ------------------------------------------------------------
NEXT_PUBLIC_FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
