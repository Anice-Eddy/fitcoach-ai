# ============================================================
# FITCOACH AI — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# Ne jamais committer .env.local dans git
# ============================================================

# ------------------------------------------------------------
# BASE DE DONNÉES — Neon PostgreSQL
# https://neon.tech → créer un projet → copier l'URL
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host/BodyOps?sslmode=require"

# ------------------------------------------------------------
# NEXTAUTH v5
# NEXTAUTH_SECRET : générer avec `openssl rand -base64 32`
# NEXTAUTH_URL    : http://localhost:3000 en dev, URL Vercel en prod
# ------------------------------------------------------------
NEXTAUTH_SECRET="REMPLACER_PAR_SECRET_32_CARACTERES"
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# OAUTH — GitHub
# https://github.com/settings/developers → New OAuth App
# URI de redirection : {NEXTAUTH_URL}/api/auth/callback/github
# ------------------------------------------------------------
GITHUB_ID=""
GITHUB_SECRET=""

# ------------------------------------------------------------
# STRIPE
# https://dashboard.stripe.com → Developers → API Keys
# STRIPE_WEBHOOK_SECRET : stripe listen --forward-to localhost:3000/api/stripe/webhook
# ------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# IDs des produits/prix Stripe (créer dans le dashboard Stripe)
STRIPE_PRO_MONTHLY_ID="price_..."
STRIPE_PRO_YEARLY_ID="price_..."
STRIPE_ELITE_MONTHLY_ID="price_..."
STRIPE_ELITE_YEARLY_ID="price_..."
STRIPE_BUSINESS_ID="price_..."

# ------------------------------------------------------------
# INTÉGRATIONS SPORTIVES — toutes optionnelles au MVP
# (architecture mockée, décommenter quand ready)
# ------------------------------------------------------------

# Strava — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""

# Fitbit — https://dev.fitbit.com/apps
FITBIT_CLIENT_ID=""
FITBIT_CLIENT_SECRET=""

# Garmin — https://developer.garmin.com
GARMIN_CLIENT_ID=""
GARMIN_CLIENT_SECRET=""

# ------------------------------------------------------------
# AFFILIATION
# Amazon Associates : https://affiliate-program.amazon.com
# ------------------------------------------------------------
AMAZON_AFFILIATE_TAG=""

# ------------------------------------------------------------
# APP
# NEXT_PUBLIC_* est exposé côté client (pas de secrets ici)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ------------------------------------------------------------
# AUTH — Mode progressif NextAuth / Firebase
# nextauth = auth actuelle uniquement
# firebase = Firebase uniquement
# hybrid   = NextAuth + Firebase pendant la migration
# ------------------------------------------------------------
AUTH_PROVIDER="hybrid"
NEXT_PUBLIC_AUTH_PROVIDER="hybrid"

# ------------------------------------------------------------
# RATE LIMIT — Upstash Redis
# Upstash Console → Redis → REST URL / REST Token
# Utilisé en production pour protéger auth, chat, notes, IA, coach et Apple Health.
# ------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ------------------------------------------------------------
# FIREBASE AUTH — Client SDK
# Firebase Console → Project settings → General → Web app config
# NEXT_PUBLIC_* est visible côté navigateur, ce ne sont pas des secrets.
# ------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# ------------------------------------------------------------
# FIREBASE AUTH — Admin SDK
# Firebase Console → Project settings → Service accounts
# Option recommandée : coller le JSON complet dans FIREBASE_SERVICE_ACCOUNT_JSON.
# En local, remplacer les sauts de ligne de private_key par \n.
# ------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Option alternative si tu ne veux pas utiliser le JSON complet.
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""

# Anciennes variables compatibles, conservées pendant la migration.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ------------------------------------------------------------
# FACEBOOK LOGIN — utilisé par Firebase Auth côté provider
# Facebook Developer Console → App settings
# NEXT_PUBLIC_FACEBOOK_APP_ID est public, FACEBOOK_APP_SECRET reste serveur.
# ------------------------------------------------------------
NEXT_PUBLIC_FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
