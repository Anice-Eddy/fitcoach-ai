// ============================================================
// FITCOACH AI - Prisma schema
// Database: PostgreSQL via Neon
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Provider {
  GOOGLE
  GITHUB
  FACEBOOK
  EMAIL
}

enum SubscriptionPlan {
  FREE
  PRO
  ELITE
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

enum Gender {
  MALE
  FEMALE
}

enum ActivityLevel {
  SEDENTARY         // 1.2  - desk work, no exercise
  LIGHTLY_ACTIVE    // 1.375 - 1-3 days/week
  MODERATELY_ACTIVE // 1.55  - 3-5 days/week
  VERY_ACTIVE       // 1.725 - 6-7 days/week
  EXTREMELY_ACTIVE  // 1.9   - athlete, twice daily
}

enum FitnessGoal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  MAINTENANCE
  ENDURANCE
  FLEXIBILITY
  GENERAL_FITNESS
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ATHLETE
}

enum BodyFocus {
  UPPER_BODY
  LOWER_BODY
  FULL_BODY
}

enum WeightUnit {
  KG
  LB
}

enum HeightUnit {
  CM
  FT_IN
}

enum WorkoutStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum MealType {
  BREAKFAST
  MORNING_SNACK
  LUNCH
  PRE_WORKOUT
  DINNER
  POST_WORKOUT
}

enum HabitType {
  WATER
  SLEEP
  PROTEIN
  STEPS
  CARDIO
  MEDITATION
}

enum MissionType {
  HABIT
  NUTRITION
  TRAINING
  RECOVERY
  CUSTOM
}

enum ExportType {
  PDF_TRAINING
  PDF_NUTRITION
  PDF_PROFILE
  JSON_ALL
}

enum IntegrationService {
  GOOGLE_FIT
  STRAVA
  FITBIT
  GARMIN
  APPLE_HEALTH
  MYFITNESSPAL
  EVOLT_ACTIVE
}

enum AffiliateCategory {
  SUPPLEMENTS
  EQUIPMENT
  CLOTHING
  BOOKS
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  FOREARMS
  CORE
  QUADS
  HAMSTRINGS
  GLUTES
  CALVES
  FULL_BODY
  CARDIO
}

enum Equipment {
  BARBELL
  DUMBBELL
  KETTLEBELL
  RESISTANCE_BAND
  PULL_UP_BAR
  BENCH
  CABLE_MACHINE
  SMITH_MACHINE
  BODYWEIGHT
  CARDIO_MACHINE
  CHEST_PRESS_MACHINE
  HIP_THRUST_MACHINE
}

// ============================================================
// MODELS
// ============================================================

// Main user account
model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  emailVerified      DateTime?
  name               String?
  image              String?
  password           String?
  provider           Provider           @default(EMAIL)
  firebaseUid        String?            @unique @map("firebase_uid")
  authProvider       String?            @map("auth_provider")
  firebaseEmailVerified Boolean         @default(false) @map("email_verified")
  lastLoginAt        DateTime?          @map("last_login_at")
  authMigratedAt     DateTime?          @map("auth_migrated_at")
  stripeCustomerId   String?            @unique
  subscriptionPlan   SubscriptionPlan   @default(FREE)
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  profile             Profile?
  passwordResetTokens PasswordResetToken[]
  authHandoffTokens   AuthHandoffToken[]
  bodyMetrics         BodyMetric[]
  workoutPrograms     WorkoutProgram[]
  workoutSessions     WorkoutSession[]
  nutritionPlans      NutritionPlan[]
  nutritionLogs       NutritionLog[]
  createdFoodItems    FoodLibraryItem[]
  dailyHabitLogs      DailyHabitLog[]
  dailyMissions       DailyMission[]
  bodyOpsScores       BodyOpsScore[]
  shoppingLists       ShoppingList[]
  integrationAccounts IntegrationAccount[]
  exportHistory       ExportHistory[]
  subscription        Subscription?
  affiliateClicks     AffiliateClick[]
  coachProfile        CoachProfile?
  accounts            Account[]
  sessions            Session[]

  // Coach relations
  coachMembers            CoachMember[]       @relation("CoachMembers")
  appointmentsAsMember    CoachAppointment[]  @relation("AppointmentsAsMember")
  coachNotes              CoachNote[]         @relation("CoachNotes")
  coachNoteReplies        CoachNoteReply[]    @relation("NoteReplies")
  authoredCoachNoteReplies CoachNoteReply[]   @relation("CoachNoteReplyAuthor")
  coachChatMessages        CoachChatMessage[]  @relation("CoachChatMessageSender")
  coachChatMemberships     CoachChat[]         @relation("CoachChatMember")
  receivedNotifications   Notification[]      @relation("NotificationRecipient")
  userNotes               UserNote[]
  aiUsageDaily            AIUsageDaily[]

  @@index([email])
  @@index([firebaseUid])
  @@index([stripeCustomerId])
  @@map("users")
}

// User physical profile and preferences
model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  firstName String
  age       Int
  gender    Gender

  // Body measurements
  weightKg   Float
  heightCm   Float
  waistCm    Float?
  hipsCm     Float?
  weightUnit WeightUnit @default(KG)
  heightUnit HeightUnit @default(CM)

  // Activity
  activityLevel       ActivityLevel
  availableEquipment  Equipment[]
  trainingDaysPerWeek Int          @default(3)

  // Goals
  fitnessGoal    FitnessGoal
  targetWeightKg Float?
  fitnessLevel   FitnessLevel
  bodyFocus      BodyFocus?   @default(FULL_BODY)

  // Injuries / physical constraints
  injuries Json?  // InjuryEntry[]  { bodyPart, severity, description }

  // Nutrition
  dietaryRestrictions String[]
  foodPreferences     String[]

  // Automatic calculations (updated whenever the profile changes)
  bmi                 Float?
  bmr                 Float?
  tdee                Float?
  recommendedCalories Float?
  recommendedProteinG Float?
  recommendedCarbsG   Float?
  recommendedFatG     Float?

  // App preferences
  language            String  @default("fr")
  darkMode            Boolean @default(true)
  onboardingCompleted Boolean @default(false)

  // AI settings
  aiMemoryEnabled  Boolean @default(true)
  aiHistoryEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("profiles")
}

// Body measurement history
model BodyMetric {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date         DateTime @default(now())
  weightKg     Float?
  bodyFatPct   Float?
  muscleMassKg Float?
  waistCm      Float?
  hipsCm       Float?
  chestCm      Float?
  armCm        Float?

  // Daily signals used to connect progress with lifestyle.
  steps            Int?
  sleepHours       Float?
  waterLiters      Float?
  energyLevel      Int?
  stressLevel      Int?
  progressPhotoUrl String?

  // Apple Health data synced through the BodyOps iOS Shortcut.
  heartRateAvg     Int?   // Daily average heart rate (bpm)
  caloriesActive   Int?   // Active calories burned (kcal)
  restingHeartRate Int?   // Resting heart rate (bpm) - strong cardiovascular fitness indicator
  vo2Max           Float? // Estimated VO2 max (ml/kg/min) - requires Apple Watch
  hrv              Float? // SDNN heart-rate variability (ms) - Apple Watch recovery indicator
  spo2             Float? // Blood oxygen saturation (%) - Apple Watch Series 6+

  // Evolt Active data (advanced body composition)
  evoltBioAge Float?
  evoltBwi    Float?
  evoltBmr    Float?

  // Renpho data (smart scale)
  renphoFatFreeMassKg    Float?
  renphoSubcutaneousFatPct Float?
  renphoVisceralFat      Float?
  renphoBodyWaterPct     Float?
  renphoSkeletalMusclePct Float?
  renphoBoneMassKg       Float?
  renphoProteinPct       Float?
  renphoBmr              Float?
  renphoMetabolicAge     Int?
  renphoBmi              Float?

  notes String?

  createdAt DateTime @default(now())

  @@index([userId, date])
  @@map("body_metrics")
}

// Multi-week workout program
model WorkoutProgram {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  fitnessGoal  FitnessGoal
  fitnessLevel FitnessLevel
  weeksTotal   Int          @default(8)
  currentWeek  Int          @default(1)
  isActive     Boolean      @default(true)

  sessions WorkoutSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@map("workout_programs")
}

// Individual workout session
model WorkoutSession {
  id      String  @id @default(cuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program WorkoutProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  programId String?

  name            String
  dayOfWeek       Int?          // 0=Monday ... 6=Sunday
  weekNumber      Int?
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  durationMinutes Int?
  status          WorkoutStatus @default(PLANNED)
  notes           String?
  caloriesBurned  Int?

  exerciseLogs ExerciseLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, scheduledAt])
  @@map("workout_sessions")
}

// Exercise library shared across users
model Exercise {
  id           String       @id @default(cuid())
  name         String
  nameEn       String?
  description  String?
  instructions String[]
  muscleGroups MuscleGroup[]
  equipment    Equipment[]
  imageUrl     String?
  videoUrl     String?
  isCompound   Boolean      @default(false)

  exerciseLogs ExerciseLog[]

  createdAt DateTime @default(now())

  @@index([name])
  @@map("exercises")
}

// Exercise log within a workout session
model ExerciseLog {
  id         String         @id @default(cuid())
  sessionId  String
  session    WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])

  order            Int
  sets             Int
  reps             Int
  weightKg         Float?
  restSeconds      Int?
  tempo            String?  // Example: "3-1-2-0" (eccentric-pause-concentric-pause)
  rpe              Int?     // Rate of Perceived Exertion 1-10
  isCompleted      Boolean  @default(false)
  notes            String?
  velocityPeakMps  Float?   @map("velocity_peak_mps")
  velocityAvgMps   Float?   @map("velocity_avg_mps")
  barPathDeviationCm Float? @map("bar_path_deviation_cm")
  barPathPoints    Json?    @map("bar_path_points")

  // Previous-week reference for progressive overload
  previousWeightKg Float?
  previousReps     Int?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([exerciseId])
  @@map("exercise_logs")
}

// Weekly nutrition plan
model NutritionPlan {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String   @default("Mon plan nutritionnel")
  targetCalories Float
  targetProteinG Float
  targetCarbsG   Float
  targetFatG     Float
  weekStartDate  DateTime
  isActive       Boolean  @default(true)

  meals         Meal[]
  shoppingLists ShoppingList[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@map("nutrition_plans")
}

// Meal inside a nutrition plan
model Meal {
  id     String        @id @default(cuid())
  planId String
  plan   NutritionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  dayOfWeek     Int       // 0=Monday ... 6=Sunday
  type          MealType
  name          String
  scheduledTime String?   // Example: "08:00"
  totalCalories Float
  totalProteinG Float
  totalCarbsG   Float
  totalFatG     Float
  isLogged      Boolean   @default(false)

  foodItems FoodItem[]

  createdAt DateTime @default(now())

  @@index([planId, dayOfWeek])
  @@map("meals")
}

// Food item inside a meal
model FoodItem {
  id     String @id @default(cuid())
  mealId String
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  name        String
  brand       String?
  gramsAmount Float
  calories    Float
  proteinG    Float
  carbsG      Float
  fatG        Float
  fiberG      Float?
  sugarG      Float?

  // Optional affiliate link for recommended meal supplements
  affiliateProductId String?
  affiliateProduct   AffiliateProduct? @relation(fields: [affiliateProductId], references: [id])

  createdAt DateTime @default(now())

  @@index([mealId])
  @@map("food_items")
}

// Daily nutrition log manually entered by the user
model NutritionLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      String   // YYYY-MM-DD, stable for daily dashboard resets
  clientKey String   // meal:<id> or manual:<id>, unique per day
  source    String   @default("PLANNED")
  mealType  MealType?
  name      String

  calories Float
  proteinG Float
  carbsG   Float
  fatG     Float
  items    Json?

  loggedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date, clientKey])
  @@index([userId, date])
  @@index([userId, loggedAt])
  @@map("nutrition_logs")
}

// Shared food library: static BodyOps foods remain code-owned,
// these entries are user-created and can be visible to everyone.
model FoodLibraryItem {
  id              String  @id @default(cuid())
  createdByUserId String? @map("created_by_user_id")
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  name       String
  nameFr     String? @map("name_fr")
  nameEn     String? @map("name_en")
  brand      String?
  category   String
  visibility String  @default("PUBLIC")
  source     String  @default("USER")

  caloriesPer100g Float @map("calories_per_100g")
  proteinPer100g  Float @map("protein_per_100g")
  carbsPer100g    Float @map("carbs_per_100g")
  fatPer100g      Float @map("fat_per_100g")
  fiberPer100g    Float? @map("fiber_per_100g")
  sugarPer100g    Float? @map("sugar_per_100g")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([visibility, deletedAt])
  @@index([createdByUserId, deletedAt])
  @@map("food_library_items")
}

// Daily tracking for key BodyOps habits
model DailyHabitLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date        String
  type        HabitType
  targetValue Float?
  actualValue Float?
  unit        String?
  isCompleted Boolean @default(false)
  source      String  @default("USER")
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date, type])
  @@index([userId, date])
  @@map("daily_habit_logs")
}

// Daily mission computed or validated by the user
model DailyMission {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date        String
  key         String
  title       String
  type        MissionType
  targetValue Float?
  actualValue Float?
  unit        String?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date, key])
  @@index([userId, date])
  @@map("daily_missions")
}

// Daily BodyOps score /100, composed from the main pillars
model BodyOpsScore {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date             String
  score            Int
  nutritionScore   Int @default(0)
  trainingScore    Int @default(0)
  recoveryScore    Int @default(0)
  habitScore       Int @default(0)
  progressionScore Int @default(0)
  activityScore    Int @default(0)
  metadata         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
  @@map("bodyops_scores")
}

// Shopping list generated from the nutrition plan
model ShoppingList {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId String?
  plan   NutritionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  weekOf   DateTime
  // [{ name, amount, unit, category, checked, affiliateUrl? }]
  items    Json
  isActive Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("shopping_lists")
}

// External integration account (Strava, Fitbit, etc.)
model IntegrationAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  service      IntegrationService
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  isConnected  Boolean            @default(false)
  lastSyncedAt DateTime?
  metadata     Json?              // service-specific data

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, service])
  @@index([userId])
  @@map("integration_accounts")
}

// Export history (PDF / JSON)
model ExportHistory {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      ExportType
  fileName  String
  sizeBytes Int?
  url       String?    // temporary URL when stored in cloud

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("export_history")
}

// User Stripe subscription
model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan                   SubscriptionPlan   @default(FREE)
  status                 SubscriptionStatus @default(INACTIVE)
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

// Affiliate product (supplement, equipment, clothing, book)
model AffiliateProduct {
  id          String            @id @default(cuid())
  name        String
  brand       String?
  description String?
  category    AffiliateCategory
  affiliateUrl String
  imageUrl    String?
  price       Float?
  commissionRateMin Float       // %
  commissionRateMax Float       // %
  fitnessGoals FitnessGoal[]
  isActive    Boolean           @default(true)
  tags        String[]

  clicks    AffiliateClick[]
  foodItems FoodItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("affiliate_products")
}

// Affiliate-link click (GDPR tracking)
model AffiliateClick {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  productId String
  product   AffiliateProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  category  AffiliateCategory
  source    String?            // click source page
  userAgent String?
  ipHash    String?            // hashed IP for GDPR compliance

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
  @@map("affiliate_clicks")
}

// Coach enums
enum AppointmentStatus {
  PENDING
  PROPOSED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  APPOINTMENT
  MEMBER_UPDATE
  NEW_MEMBER
  MESSAGE
  SYSTEM
}

enum CoachVerificationStatus {
  PENDING_VERIFICATION
  NEEDS_CORRECTION
  VERIFIED
  REJECTED
}

enum AIAgentType {
  TRAINING
  NUTRITION
  PROGRESSION
  MOTIVATION
  COACH_REPORT
}

enum AIProvider {
  GEMINI
  GROQ
}

enum AIReportType {
  MEMBER_ANALYSIS
  WORKOUT_PLAN
  NUTRITION_PLAN
  COACH_REPORT
}

// Coach profile - structure for Phase 2 B2B Coach
model CoachProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName       String?
  lastName        String?
  birthDate       DateTime?
  avatarUrl       String?
  bio             String?
  specialties     String[]
  certifications  String[]
  yearsExperience Int?
  city            String?
  country         String? // Coach country, displayed on the public profile
  phone           String?
  isVerified      Boolean  @default(false)
  memberLimit     Int      @default(10)
  showMemberCount Boolean  @default(true)
  showYearsExperience Boolean @default(true)
  publicRating    Float?
  publicRatingCount Int    @default(0)
  showPublicRating Boolean @default(false)
  discoveryCallEnabled Boolean @default(true)
  discoveryCallTitle String @default("Discovery call")
  discoveryCallDuration Int @default(30)
  showDiscoveryCall Boolean @default(true)
  verificationStatus CoachVerificationStatus @default(NEEDS_CORRECTION)
  verificationIssues Json?
  verificationAnalysis Json?
  documentFileName   String?
  documentMimeType   String?
  documentSize       Int?
  documentUploadedAt DateTime?
  adminFeedback      String?

  coachMembers  CoachMember[]
  appointments  CoachAppointment[]
  notifications Notification[]
  notes         CoachNote[]
  availability  CoachAvailability[]
  chats         CoachChat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coach_profiles")
}

// Members tracked by a coach
model CoachMember {
  id           String @id @default(cuid())
  coachId      String
  coachProfile CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  
  memberId String
  member   User   @relation("CoachMembers", fields: [memberId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())
  lastUpdated DateTime @updatedAt

  @@unique([coachId, memberId])
  @@index([coachId])
  @@index([memberId])
  @@map("coach_members")
}

// Coach/member appointment
model CoachAppointment {
  id           String @id @default(cuid())
  coachId      String
  coachProfile CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  
  memberId String
  member   User   @relation("AppointmentsAsMember", fields: [memberId], references: [id], onDelete: Cascade)

  title       String
  description String?
  scheduledAt DateTime
  duration    Int      @default(60)  // in minutes
  status      AppointmentStatus @default(PENDING)
  meetLink    String?
  coachNote   String?
  memberNote  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId])
  @@index([memberId])
  @@index([scheduledAt])
  @@map("coach_appointments")
}

// Recurring coach availability slots by weekday
model CoachAvailability {
  id           String       @id @default(cuid())
  coachId      String
  coachProfile CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)

  dayOfWeek    Int  // 1=Monday, 2=Tuesday, ... 7=Sunday (ISO)
  startHour    Int  // 0-23
  startMinute  Int  @default(0)
  endHour      Int  // 0-23
  endMinute    Int  @default(0)
  slotDuration Int  @default(60)  // slot duration in minutes

  createdAt DateTime @default(now())

  @@unique([coachId, dayOfWeek, startHour, startMinute])
  @@map("coach_availabilities")
}

// Coach/member notifications
model Notification {
  id           String @id @default(cuid())
  coachId      String
  coachProfile CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)

  recipientUserId String?
  recipient       User?   @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  type       NotificationType
  title      String
  message    String
  relatedId  String?
  isRead     Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([coachId])
  @@index([recipientUserId])
  @@index([isRead])
  @@map("notifications")
}

// Coach notes about a member
model CoachNote {
  id           String @id @default(cuid())
  coachId      String
  coachProfile CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)

  memberId String
  member   User   @relation("CoachNotes", fields: [memberId], references: [id], onDelete: Cascade)

  title   String
  content String
  category String?  // PROGRESS, FEEDBACK, WORKOUT, NUTRITION, etc.
  status   String   @default("OPEN")
  priority String   @default("MEDIUM")
  tags     String[]
  followUpAt DateTime?
  isPinned           Boolean @default(false)
  isSharedWithMember Boolean @default(false)
  isImportant        Boolean @default(false)

  replies CoachNoteReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId])
  @@index([memberId])
  @@index([status])
  @@index([isPinned])
  @@map("coach_notes")
}

model CoachNoteReply {
  id       String    @id @default(cuid())
  noteId   String
  note     CoachNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  memberId String?
  member   User?     @relation("NoteReplies", fields: [memberId], references: [id], onDelete: Cascade)
  authorUserId String?
  author      User?  @relation("CoachNoteReplyAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  authorRole  String @default("MEMBER")
  content  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([noteId])
  @@index([memberId])
  @@index([authorUserId])
  @@map("coach_note_replies")
}

// Direct coach/member conversation
model CoachChat {
  id           String @id @default(cuid())
  coachId      String
  coachProfile CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)

  memberId String
  member   User   @relation("CoachChatMember", fields: [memberId], references: [id], onDelete: Cascade)

  messages CoachChatMessage[]

  lastMessageAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([coachId, memberId])
  @@index([coachId, lastMessageAt])
  @@index([memberId, lastMessageAt])
  @@map("coach_chats")
}

model CoachChatMessage {
  id     String @id @default(cuid())
  chatId String
  chat   CoachChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  senderUserId String
  sender       User   @relation("CoachChatMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  content String @db.Text
  readAt  DateTime?

  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
  @@index([senderUserId])
  @@map("coach_chat_messages")
}

model UserNote {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title    String
  content  String
  category String?
  tags     String[]
  isPinned Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isPinned])
  @@map("user_notes")
}

model AIConversation {
  id        String      @id @default(cuid())
  userId    String
  memberId  String
  coachId   String?
  agentType AIAgentType
  title     String?

  messages AIMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([memberId, createdAt])
  @@index([coachId, createdAt])
  @@index([agentType])
  @@map("ai_conversations")
}

model AIMessage {
  id             String          @id @default(cuid())
  conversationId String
  conversation   AIConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  memberId       String
  coachId        String?
  role           String
  content        String          @db.Text
  prompt         String?         @db.Text
  response       String?         @db.Text
  provider       AIProvider?
  agentType      AIAgentType

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@index([memberId, createdAt])
  @@index([coachId, createdAt])
  @@map("ai_messages")
}

model AIMemory {
  id        String      @id @default(cuid())
  userId    String
  memberId  String
  coachId   String?
  agentType AIAgentType

  firstName   String?
  summary     String?  @db.Text
  preferences String[] @default([])
  topics      String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, memberId, agentType])
  @@index([memberId, agentType])
  @@index([coachId, agentType])
  @@map("ai_memories")
}

model AIReport {
  id        String       @id @default(cuid())
  userId    String
  memberId  String
  coachId   String?
  type      AIReportType
  agentType AIAgentType
  prompt    String       @db.Text
  response  String       @db.Text
  provider  AIProvider
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([memberId, createdAt])
  @@index([coachId, createdAt])
  @@index([type])
  @@map("ai_reports")
}

// Legacy daily AI-call tracking, kept for exports and existing-data cleanup.
model AIUsageDaily {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   String // YYYY-MM-DD
  count  Int    @default(0)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("ai_usage_daily")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model AuthHandoffToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_handoff_tokens")
}

// ============================================================
// NEXT-AUTH - required by PrismaAdapter
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
