// ============================================================
// FITCOACH AI — Schéma Prisma
// Base de données : PostgreSQL via Neon
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Provider {
  GOOGLE
  GITHUB
  EMAIL
}

enum SubscriptionPlan {
  FREE
  PRO
  ELITE
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

enum Gender {
  MALE
  FEMALE
}

enum ActivityLevel {
  SEDENTARY         // 1.2  — bureau, pas d'exercice
  LIGHTLY_ACTIVE    // 1.375 — 1-3j/semaine
  MODERATELY_ACTIVE // 1.55  — 3-5j/semaine
  VERY_ACTIVE       // 1.725 — 6-7j/semaine
  EXTREMELY_ACTIVE  // 1.9   — athlète 2x/jour
}

enum FitnessGoal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  MAINTENANCE
  ENDURANCE
  FLEXIBILITY
  GENERAL_FITNESS
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ATHLETE
}

enum WeightUnit {
  KG
  LB
}

enum HeightUnit {
  CM
  FT_IN
}

enum WorkoutStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum MealType {
  BREAKFAST
  MORNING_SNACK
  LUNCH
  PRE_WORKOUT
  DINNER
  POST_WORKOUT
}

enum ExportType {
  PDF_TRAINING
  PDF_NUTRITION
  PDF_PROFILE
  JSON_ALL
}

enum IntegrationService {
  GOOGLE_FIT
  STRAVA
  FITBIT
  GARMIN
  APPLE_HEALTH
  EVOLT_ACTIVE
}

enum AffiliateCategory {
  SUPPLEMENTS
  EQUIPMENT
  CLOTHING
  BOOKS
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  FOREARMS
  CORE
  QUADS
  HAMSTRINGS
  GLUTES
  CALVES
  FULL_BODY
}

enum Equipment {
  BARBELL
  DUMBBELL
  KETTLEBELL
  RESISTANCE_BAND
  PULL_UP_BAR
  BENCH
  CABLE_MACHINE
  SMITH_MACHINE
  BODYWEIGHT
  CARDIO_MACHINE
}

// ============================================================
// MODÈLES
// ============================================================

// Compte utilisateur principal
model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  emailVerified      DateTime?
  name               String?
  image              String?
  password           String?
  provider           Provider           @default(EMAIL)
  stripeCustomerId   String?            @unique
  subscriptionPlan   SubscriptionPlan   @default(FREE)
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  profile             Profile?
  passwordResetTokens PasswordResetToken[]
  bodyMetrics         BodyMetric[]
  workoutPrograms     WorkoutProgram[]
  workoutSessions     WorkoutSession[]
  nutritionPlans      NutritionPlan[]
  shoppingLists       ShoppingList[]
  integrationAccounts IntegrationAccount[]
  exportHistory       ExportHistory[]
  subscription        Subscription?
  affiliateClicks     AffiliateClick[]
  coachProfile        CoachProfile?
  accounts            Account[]
  sessions            Session[]

  // Coach relations
  coachMembers            CoachMember[]       @relation("CoachMembers")
  appointmentsAsMember    CoachAppointment[]  @relation("AppointmentsAsMember")
  coachNotes              CoachNote[]         @relation("CoachNotes")
  coachNoteReplies        CoachNoteReply[]    @relation("NoteReplies")
  receivedNotifications   Notification[]      @relation("NotificationRecipient")
  userNotes               UserNote[]

  @@index([email])
  @@index([stripeCustomerId])
  @@map("users")
}

// Profil physique et préférences de l'utilisateur
model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identité
  firstName String
  age       Int
  gender    Gender

  // Mensurations
  weightKg   Float
  heightCm   Float
  waistCm    Float?
  hipsCm     Float?
  weightUnit WeightUnit @default(KG)
  heightUnit HeightUnit @default(CM)

  // Activité
  activityLevel       ActivityLevel
  availableEquipment  Equipment[]
  trainingDaysPerWeek Int          @default(3)

  // Objectifs
  fitnessGoal    FitnessGoal
  targetWeightKg Float?
  fitnessLevel   FitnessLevel

  // Alimentation
  dietaryRestrictions String[]
  foodPreferences     String[]

  // Calculs automatiques (mis à jour à chaque modification du profil)
  bmi                 Float?
  bmr                 Float?
  tdee                Float?
  recommendedCalories Float?
  recommendedProteinG Float?
  recommendedCarbsG   Float?
  recommendedFatG     Float?

  // Préférences app
  language            String  @default("fr")
  darkMode            Boolean @default(true)
  onboardingCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("profiles")
}

// Historique des mesures corporelles
model BodyMetric {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date         DateTime @default(now())
  weightKg     Float
  bodyFatPct   Float?
  muscleMassKg Float?
  waistCm      Float?
  hipsCm       Float?
  chestCm      Float?
  armCm        Float?

  // Données Evolt Active (composition corporelle avancée)
  evoltBioAge Float?
  evoltBwi    Float?
  evoltBmr    Float?

  notes String?

  createdAt DateTime @default(now())

  @@index([userId, date])
  @@map("body_metrics")
}

// Programme d'entraînement (multi-semaines)
model WorkoutProgram {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  fitnessGoal  FitnessGoal
  fitnessLevel FitnessLevel
  weeksTotal   Int          @default(8)
  currentWeek  Int          @default(1)
  isActive     Boolean      @default(true)

  sessions WorkoutSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@map("workout_programs")
}

// Séance d'entraînement individuelle
model WorkoutSession {
  id      String  @id @default(cuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program WorkoutProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  programId String?

  name            String
  dayOfWeek       Int?          // 0=lundi … 6=dimanche
  weekNumber      Int?
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  durationMinutes Int?
  status          WorkoutStatus @default(PLANNED)
  notes           String?
  caloriesBurned  Int?

  exerciseLogs ExerciseLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, scheduledAt])
  @@map("workout_sessions")
}

// Bibliothèque d'exercices (partagée entre tous les utilisateurs)
model Exercise {
  id           String       @id @default(cuid())
  name         String
  nameEn       String?
  description  String?
  instructions String[]
  muscleGroups MuscleGroup[]
  equipment    Equipment[]
  imageUrl     String?
  videoUrl     String?
  isCompound   Boolean      @default(false)

  exerciseLogs ExerciseLog[]

  createdAt DateTime @default(now())

  @@index([name])
  @@map("exercises")
}

// Log d'un exercice au sein d'une séance
model ExerciseLog {
  id         String         @id @default(cuid())
  sessionId  String
  session    WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])

  order            Int
  sets             Int
  reps             Int
  weightKg         Float?
  restSeconds      Int?
  tempo            String?  // ex: "3-1-2-0" (excentrique-pause-concentrique-pause)
  rpe              Int?     // Rate of Perceived Exertion 1-10
  isCompleted      Boolean  @default(false)
  notes            String?

  // Référence semaine précédente pour surcharge progressive
  previousWeightKg Float?
  previousReps     Int?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([exerciseId])
  @@map("exercise_logs")
}

// Plan nutritionnel hebdomadaire
model NutritionPlan {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String   @default("Mon plan nutritionnel")
  targetCalories Float
  targetProteinG Float
  targetCarbsG   Float
  targetFatG     Float
  weekStartDate  DateTime
  isActive       Boolean  @default(true)

  meals         Meal[]
  shoppingLists ShoppingList[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@map("nutrition_plans")
}

// Repas au sein d'un plan nutritionnel
model Meal {
  id     String        @id @default(cuid())
  planId String
  plan   NutritionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  dayOfWeek     Int       // 0=lundi … 6=dimanche
  type          MealType
  name          String
  scheduledTime String?   // ex: "08:00"
  totalCalories Float
  totalProteinG Float
  totalCarbsG   Float
  totalFatG     Float
  isLogged      Boolean   @default(false)

  foodItems FoodItem[]

  createdAt DateTime @default(now())

  @@index([planId, dayOfWeek])
  @@map("meals")
}

// Aliment au sein d'un repas
model FoodItem {
  id     String @id @default(cuid())
  mealId String
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  name        String
  brand       String?
  gramsAmount Float
  calories    Float
  proteinG    Float
  carbsG      Float
  fatG        Float
  fiberG      Float?
  sugarG      Float?

  // Lien affilié optionnel (complément recommandé dans le repas)
  affiliateProductId String?
  affiliateProduct   AffiliateProduct? @relation(fields: [affiliateProductId], references: [id])

  createdAt DateTime @default(now())

  @@index([mealId])
  @@map("food_items")
}

// Liste de courses générée depuis le plan nutritionnel
model ShoppingList {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId String?
  plan   NutritionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  weekOf   DateTime
  // [{ name, amount, unit, category, checked, affiliateUrl? }]
  items    Json
  isActive Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("shopping_lists")
}

// Compte d'intégration externe (Strava, Fitbit, etc.)
model IntegrationAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  service      IntegrationService
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  isConnected  Boolean            @default(false)
  lastSyncedAt DateTime?
  metadata     Json?              // données spécifiques au service

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, service])
  @@index([userId])
  @@map("integration_accounts")
}

// Historique des exports (PDF / JSON)
model ExportHistory {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      ExportType
  fileName  String
  sizeBytes Int?
  url       String?    // URL temporaire si stocké sur cloud

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("export_history")
}

// Abonnement Stripe de l'utilisateur
model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan                   SubscriptionPlan   @default(FREE)
  status                 SubscriptionStatus @default(INACTIVE)
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

// Produit affilié (complément, équipement, vêtement, livre)
model AffiliateProduct {
  id          String            @id @default(cuid())
  name        String
  brand       String?
  description String?
  category    AffiliateCategory
  affiliateUrl String
  imageUrl    String?
  price       Float?
  commissionRateMin Float       // %
  commissionRateMax Float       // %
  fitnessGoals FitnessGoal[]
  isActive    Boolean           @default(true)
  tags        String[]

  clicks    AffiliateClick[]
  foodItems FoodItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("affiliate_products")
}

// Clic sur un lien affilié (tracking RGPD)
model AffiliateClick {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  productId String
  product   AffiliateProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  category  AffiliateCategory
  source    String?            // page d'origine du clic
  userAgent String?
  ipHash    String?            // IP hashée pour conformité RGPD

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
  @@map("affiliate_clicks")
}

// Enums pour Coach
enum AppointmentStatus {
  PENDING
  PROPOSED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  APPOINTMENT
  MEMBER_UPDATE
  NEW_MEMBER
  MESSAGE
  SYSTEM
}

enum CoachVerificationStatus {
  PENDING_VERIFICATION
  NEEDS_CORRECTION
  VERIFIED
  REJECTED
}

enum AIAgentType {
  TRAINING
  NUTRITION
  PROGRESSION
  MOTIVATION
  COACH_REPORT
}

enum AIProvider {
  GEMINI
  GROQ
}

enum AIReportType {
  MEMBER_ANALYSIS
  WORKOUT_PLAN
  NUTRITION_PLAN
  COACH_REPORT
}

// Profil Coach — structure pour Phase 2 B2B Coach
model CoachProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName       String?
  lastName        String?
  birthDate       DateTime?
  avatarUrl       String?
  bio             String?
  specialties     String[]
  certifications  String[]
  yearsExperience Int?
  city            String?
  phone           String?
  isVerified      Boolean  @default(false)
  memberLimit     Int      @default(10)
  verificationStatus CoachVerificationStatus @default(NEEDS_CORRECTION)
  verificationIssues Json?
  verificationAnalysis Json?
  documentFileName   String?
  documentMimeType   String?
  documentSize       Int?
  documentUploadedAt DateTime?
  adminFeedback      String?

  coachMembers  CoachMember[]
  appointments  CoachAppointment[]
  notifications Notification[]
  notes         CoachNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coach_profiles")
}

// Membres suivis par un coach
model CoachMember {
  id           String @id @default(cuid())
  coachId      String
  coachProfile CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  
  memberId String
  member   User   @relation("CoachMembers", fields: [memberId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())
  lastUpdated DateTime @updatedAt

  @@unique([coachId, memberId])
  @@index([coachId])
  @@index([memberId])
  @@map("coach_members")
}

// Rendez-vous Coach ↔ Membre
model CoachAppointment {
  id           String @id @default(cuid())
  coachId      String
  coachProfile CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  
  memberId String
  member   User   @relation("AppointmentsAsMember", fields: [memberId], references: [id], onDelete: Cascade)

  title       String
  description String?
  scheduledAt DateTime
  duration    Int      @default(60)  // en minutes
  status      AppointmentStatus @default(PENDING)
  meetLink    String?
  coachNote   String?
  memberNote  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId])
  @@index([memberId])
  @@index([scheduledAt])
  @@map("coach_appointments")
}

// Notifications pour le coach
model Notification {
  id           String @id @default(cuid())
  coachId      String
  coachProfile CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)

  recipientUserId String?
  recipient       User?   @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  type       NotificationType
  title      String
  message    String
  relatedId  String?
  isRead     Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([coachId])
  @@index([recipientUserId])
  @@index([isRead])
  @@map("notifications")
}

// Notes du coach sur un membre
model CoachNote {
  id           String @id @default(cuid())
  coachId      String
  coachProfile CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)

  memberId String
  member   User   @relation("CoachNotes", fields: [memberId], references: [id], onDelete: Cascade)

  title   String
  content String
  category String?  // PROGRESS, FEEDBACK, WORKOUT, NUTRITION, etc.
  status   String   @default("OPEN")
  priority String   @default("MEDIUM")
  tags     String[]
  followUpAt DateTime?
  isPinned           Boolean @default(false)
  isSharedWithMember Boolean @default(false)
  isImportant        Boolean @default(false)

  replies CoachNoteReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId])
  @@index([memberId])
  @@index([status])
  @@index([isPinned])
  @@map("coach_notes")
}

model CoachNoteReply {
  id       String    @id @default(cuid())
  noteId   String
  note     CoachNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  memberId String
  member   User      @relation("NoteReplies", fields: [memberId], references: [id], onDelete: Cascade)
  content  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([noteId])
  @@index([memberId])
  @@map("coach_note_replies")
}

model UserNote {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title    String
  content  String
  category String?
  tags     String[]
  isPinned Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isPinned])
  @@map("user_notes")
}

model AIConversation {
  id        String      @id @default(cuid())
  userId    String
  memberId  String
  coachId   String?
  agentType AIAgentType
  title     String?

  messages AIMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([memberId, createdAt])
  @@index([coachId, createdAt])
  @@index([agentType])
  @@map("ai_conversations")
}

model AIMessage {
  id             String          @id @default(cuid())
  conversationId String
  conversation   AIConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  memberId       String
  coachId        String?
  role           String
  content        String          @db.Text
  prompt         String?         @db.Text
  response       String?         @db.Text
  provider       AIProvider?
  agentType      AIAgentType

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@index([memberId, createdAt])
  @@index([coachId, createdAt])
  @@map("ai_messages")
}

model AIMemory {
  id        String      @id @default(cuid())
  userId    String
  memberId  String
  coachId   String?
  agentType AIAgentType

  firstName   String?
  summary     String?  @db.Text
  preferences String[] @default([])
  topics      String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, memberId, agentType])
  @@index([memberId, agentType])
  @@index([coachId, agentType])
  @@map("ai_memories")
}

model AIReport {
  id        String       @id @default(cuid())
  userId    String
  memberId  String
  coachId   String?
  type      AIReportType
  agentType AIAgentType
  prompt    String       @db.Text
  response  String       @db.Text
  provider  AIProvider
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([memberId, createdAt])
  @@index([coachId, createdAt])
  @@index([type])
  @@map("ai_reports")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ============================================================
// NEXT-AUTH — requis par PrismaAdapter
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
